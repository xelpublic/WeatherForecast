@page
@model Wf.Frontend.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Перенаправление на страницу входа...</h3>
                </div>
                <div class="card-body text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-3">Пожалуйста, подождите, происходит перенаправление на страницу входа.</p>
                </div>
            </div>
        </div>
    </div>
</div>
