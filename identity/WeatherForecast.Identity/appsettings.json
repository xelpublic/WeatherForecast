{
  "ConnectionStrings": {
    "DbConnection": "Data Source=identity.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "IdentityServer4": "Information"
    }
  },
  
  "AllowedHosts": "*",
  
  "ClientSettings": {
    "ClientId": "weather-forecast-web-app",
    "ClientName": "Weather Forecast Web",
    "RedirectUris": [
      "http://localhost:3000/signin-oidc",
      "http://localhost/signin-oidc",
      "http://frontend:8080/signin-oidc"
    ],
    "AllowedCorsOrigins": [
      "http://localhost:3000",
      "http://localhost",
      "http://frontend:8080"
    ],
    "PostLogoutRedirectUris": [
      "http://localhost:3000/signout-callback-oidc",
      "http://localhost/signout-callback-oidc",
      "http://frontend:8080/signout-callback-oidc"
    ],
    "AccessTokenLifetime": 86400
  },
  
  "ApplicationSettings": {
    "Cookie": {
      "Name": "WeatherForecast.Identity.Cookie",
      "LoginPath": "/Auth/Login",
      "LogoutPath": "/Auth/Logout",
      "AccessDeniedPath": "/Auth/AccessDenied"
    },
    "Password": {
      "RequiredLength": 3,
      "RequireDigit": false,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequireLowercase": false
    }
  },
  
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/identity-log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}